{
  "$schema": "https://opencode.ai/config.json",
  "theme": "kanagawa",
  "permission": {
    "bash": "ask"
  },
  "mcp": {
    "inngest-dev": {
      "type": "remote",
      "url": "http://127.0.0.1:8288/mcp",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      }
    }
  }
}
